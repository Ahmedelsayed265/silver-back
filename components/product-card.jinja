{% if product %}
{% if product is iterable and product is not mapping and product is not string and (product is sequence or 'tuple' in product.__class__.__name__|lower or 'list' in product.__class__.__name__|lower) %}
{% set product_obj = product[-1] %}
{% else %}
{% set product_obj = product %}
{% endif %}

{% if product_obj is mapping or (product_obj is not none and product_obj is not number and product_obj is not string) %}

<a href="/products/{{ product_obj.slug }}" class="product-item position-relative {% if product_obj.is_infinite == false and product_obj.quantity <= 0 %}product-item-out-of-stock{% endif %}">
    {% if store.settings.products.wishlist_enabled == true %}
    <span class="add-to-wishlist" data-wishlist-id="{{ product_obj.id }}">
        <span zid-visible-customer="true">
            <button zid-visible-wishlist="{{ product_obj.id }}" class="icon-heart-mask filled"
                onclick="event.preventDefault(); event.stopPropagation(); addToWishlist(this, '{{ product_obj.id }}')"></button>
            <button zid-hidden-wishlist="{{ product_obj.id }}" class="icon-heart-mask"
                onclick="event.preventDefault(); event.stopPropagation(); addToWishlist(this, '{{ product_obj.id }}')"></button>
        </span>
        <button type="button" zid-visible-guest="true" class="icon-heart-mask"
            onclick="event.preventDefault(); event.stopPropagation(); handleLoginAction('{{ session.url.path }}'); return false;"></button>
        <img class="loader d-none" style="object-fit: contain;" src="{{ 'spinner.gif' | asset_url }}" width="20" height="20" />
    </span>
    {% endif %}

    <div class="d-flex flex-column justify-content-start" style="height: 100%;">
        <div class="box-1-1">
            <div class="content">
                <div class="d-flex justify-content-center" style="width: 100%; height: 100%; position: relative;">
                    {% if product_obj.badge %}
                    {% set positionProductCard = true %}
                    {% include 'vitrin:products/badge.jinja' %}
                    {% endif %}

                    <div class="product-gallery">
                        {% if product_obj.images and product_obj.images|length > 0 %}
                        {% for media in product_obj.images[:2] %}
                        <img loading="lazy" class="product-image {% if loop.index0 > 0 %}d-none{% endif %}"
                            src="{{ media.image.small }}" alt="{{ product_obj.name }}" data-index="{{ loop.index0 }}">
                        {% endfor %}
                        {% else %}
                        <img loading="lazy" class="product-image"
                            src="{{ image_url(('product-img.svg' | asset_url), w=235, q=100, f='auto') }}"
                            alt="{{ product_obj.name }}">
                        {% endif %}
                    </div>

                    {% if product_obj.images and product_obj.images|length > 1 %}
                    <div class="product-image-dots"
                        style="position: absolute; bottom: 10px; left: 0; right: 0; display: flex; justify-content: center; gap: 4px;">
                        {% for media in product_obj.images[:2] %}
                        <span class="dot {% if loop.first %}active{% endif %}"
                            style="width: 6px; height: 6px; border-radius: 50%; background-color: {% if loop.first %}#000{% else %}#ccc{% endif %}; cursor: pointer;"></span>
                        {% endfor %}
                    </div>
                    {% endif %}

                    <span class="product-card-bundle-offer" data-bundle-offer-product-id="{{ product_obj.id }}"></span>
                </div>
            </div>
        </div>

        <div class="product_content">
            <div class="product-title" style="margin-top: 15px">
                {% if product_obj.categories and product_obj.categories|length > 0 %}
                <div class="categorey-title">
                    <span>
                        {% set firstCategory = product_obj.categories|first %}
                        <small style="font-size: 1.1rem; white-space: break-spaces">{{ firstCategory.name }}</small>
                    </span>
                </div>
                {% endif %}
                <span class="title">{{ product_obj.name | safe }}</span>
            </div>

            {% if store.settings.products.reviews_enabled %}
            <div class="product-card-rating-wrapper" style="height: 18px">
                {% if product_obj.rating %}
                {% set rating=product_obj.rating.average %}{% include 'components/rating-stars.jinja' %}
                {% if product_obj.rating.total_count > 0 %}<span class="product-card-rating-count">({{
                    product_obj.rating.total_count }})</span>{% endif %}
                {% endif %}
            </div>
            {% endif %}

            {% if product_obj.is_infinite or product_obj.quantity > 0 %}
                {% if (product_obj.has_options or product_obj.has_fields) %}
                <small style="font-size: 1.1rem; white-space: break-spaces">{{ _("Available in several options")
                    }}</small>
                {% endif %}

                {% if not product_obj.is_taxable %}
                <small style="font-size: 1.1rem; white-space: break-spaces">{{ _("Tax free") }}</small>
                {% endif %}
            {% endif %}

            <div class="product-crd-spec">
                {% if product_obj.formatted_sale_price is not none %}
                <div class="section-product-price">
                    <div class="product-price theme-title-primary">
                        <span>{{ product_obj.formatted_sale_price }}</span>
                    </div>
                    <div style="color: #494949">
                        <span class="product-prev-price">{{ product_obj.formatted_price }}</span>
                    </div>
                </div>
                {% else %}
                <div class="product-price section-product-price theme-title-primary">
                    <span>{{ product_obj.formatted_price }}</span>
                </div>
                {% endif %}

                {% if product_obj.is_infinite == false and product_obj.quantity <= 0 %} <small
                    style="font-size: 1.1rem; white-space: break-spaces">{{ _("This product is out of stock") }}</small>
                    {% endif %}

                    <div class="product-card-btns" style="text-align: center; {% if product_obj.is_infinite == false and product_obj.quantity <= 0 %}margin-top: 10px; width: 100%; {% endif %}">
                        {% if product_obj.is_infinite == false and product_obj.quantity <= 0 %} 
                            <button type="button" class="btn btn-primary btn-product-card-out-of-stock" onclick="window.location.href=this.closest('a').href;">
                                <img src="{{ 'u_bell.svg' | asset_url }}" alt="" class="d-inline" />
                                <span>{{ _("Notify me when available") }}</span>
                            </button>

                        {% elif ( product_obj.has_options or product_obj.has_fields or product_obj.product_class == 'dynamic_bundle' ) %}
                            <button type="button" class="btn btn-primary btn-product-card-select-variant cart_btn" onclick="window.location.href=this.closest('a').href;">
                                <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 22 22"
                                    fill="none">
                                    <path
                                        d="M2.43848 0.25C3.70035 0.250013 4.8004 1.10881 5.10645 2.33301L5.10938 2.34668L7.6084 14.2471L14.2637 14.2471C15.3092 14.247 16.0783 14.0819 16.6611 13.8115C17.2354 13.545 17.6668 13.1584 18.0156 12.6494C18.7472 11.5816 19.1031 10.0154 19.5254 7.91797C19.6489 7.30441 19.7254 6.91631 19.7451 6.63086C19.7544 6.49631 19.7477 6.41894 19.7393 6.37598C19.7335 6.34659 19.7276 6.33685 19.7256 6.33398C19.7192 6.33045 19.699 6.31942 19.6543 6.30762C19.5334 6.27575 19.3372 6.25646 18.9863 6.25C18.5722 6.24238 18.2424 5.90041 18.25 5.48633C18.2576 5.07223 18.5996 4.74245 19.0137 4.75C19.3703 4.75657 19.7261 4.77538 20.0371 4.85742C20.3777 4.94729 20.6995 5.12229 20.9385 5.45117C21.2328 5.85625 21.271 6.31402 21.2422 6.7334C21.215 7.12856 21.1172 7.61419 21.0059 8.16699L20.9961 8.21387C20.5906 10.228 20.1913 12.1274 19.2529 13.4971C18.7668 14.2066 18.1344 14.7814 17.293 15.1719C16.46 15.5584 15.4614 15.747 14.2637 15.7471H7.9375C7.9185 15.7485 7.89925 15.75 7.87988 15.75L7.46875 15.75C6.64616 15.75 5.92133 16.3778 5.77637 17.25L16.5 17.25C17.7426 17.25 18.75 18.2574 18.75 19.5C18.75 20.7426 17.7426 21.75 16.5 21.75C15.2574 21.75 14.25 20.7426 14.25 19.5C14.25 19.2367 14.2977 18.9848 14.3809 18.75H11.6191C11.7023 18.9848 11.75 19.2367 11.75 19.5C11.75 20.7426 10.7426 21.75 9.5 21.75C8.25736 21.75 7.25 20.7426 7.25 19.5C7.25 19.2367 7.29775 18.9848 7.38086 18.75H5.41113C4.74128 18.7498 4.25 18.193 4.25 17.5713C4.25005 16.2433 5.01444 15.0715 6.1377 14.5449L3.64844 2.68457C3.50511 2.13463 3.00784 1.75001 2.43848 1.75L1.5 1.75C1.08579 1.75 0.75 1.41421 0.75 1C0.75 0.585786 1.08579 0.25 1.5 0.25L2.43848 0.25ZM9.5 18.75C9.08579 18.75 8.75 19.0858 8.75 19.5C8.75 19.9142 9.08579 20.25 9.5 20.25C9.91421 20.25 10.25 19.9142 10.25 19.5C10.25 19.0858 9.91421 18.75 9.5 18.75ZM16.5 18.75C16.0858 18.75 15.75 19.0858 15.75 19.5C15.75 19.9142 16.0858 20.25 16.5 20.25C16.9142 20.25 17.25 19.9142 17.25 19.5C17.25 19.0858 16.9142 18.75 16.5 18.75ZM12 0.75C1