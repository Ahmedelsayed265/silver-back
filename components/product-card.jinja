                                        fill="#FAFAFA"></path>
                                </svg>

                                <p>{{_("add to cart")}}</p>
                            </button>
                        {% endif %}
                    </div>
            </div>
        </div>
    </div>
</a>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll('.product-item').forEach(function (productCard) {
            var images = productCard.querySelectorAll('.product-image');
            var dots = productCard.querySelectorAll('.dot');
            var interval;
            var isHovering = false;

            if (images.length > 1 && dots.length > 0) {
                productCard.addEventListener('mouseenter', function () {
                    isHovering = true;
                    var currentIndex = 0;

                    interval = setInterval(function () {
                        if (!isHovering) {
                            clearInterval(interval);
                            return;
                        }

                        images.forEach(function (img) {
                            img.classList.add('d-none');
                        });

                        dots.forEach(function (dot) {
                            dot.style.backgroundColor = '#ccc';
                        });

                        currentIndex = (currentIndex + 1) % images.length;
                        images[currentIndex].classList.remove('d-none');
                        dots[currentIndex].style.backgroundColor = '#000';
                    }, 1500);
                });

                productCard.addEventListener('mouseleave', function () {
                    isHovering = false;
                    clearInterval(interval);

                    images.forEach(function (img) {
                        img.classList.add('d-none');
                    });
                    dots.forEach(function (dot) {
                        dot.style.backgroundColor = '#ccc';
                    });
                    images[0].classList.remove('d-none');
                    dots[0].style.backgroundColor = '#000';
                });

                dots.forEach(function (dot, index) {
                    dot.addEventListener('click', function (e) {
                        e.preventDefault();
                        e.stopPropagation();

                        images.forEach(function (img) {
                            img.classList.add('d-none');
                        });

                        dots.forEach(function (d) {
                            d.style.backgroundColor = '#ccc';
                        });

                        images[index].classList.remove('d-none');
                        dot.style.backgroundColor = '#000';
                    });
                });
            }
        });
    });
</script>
{% endif %}
{% endif %}
