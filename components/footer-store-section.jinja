            <div class="footer-copyrights-vat-certificate">
                <div class="footer-companies">
                    <div class="footer-icons">
                        <div class="icons-wrapper footer-store-section-bars">
                            <div class="logistics-pay-icons d-flex flex-wrap justify-content-center">
                                {% for shipping_method in store.settings.checkout.shipping_methods %}
                                <a href="/shipping-and-payment">
                                    <img src="{{ image_url(shipping_method.icon, h=80, q=100) }}" loading="lazy" alt=""
                                        height="21">
                                </a>
                                {% endfor %}
                                {% for payment_method in store.settings.checkout.payment_methods %}
                                <a href="/shipping-and-payment">
                                    <img src="{{ image_url(payment_method.icon, h=80, q=100) }}" loading="lazy" alt=""
                                        height="21">
                                </a>
                                {% endfor %}
                            </div>
                        </div>
                    </div>
                </div>

                <div class="vat-crn-sections py-4 d-flex flex-row flex-wrap justify-content-end align-items-center">
                    <div class="d-flex justify-content-center align-items-center">
                        <span class="text-center footer-copyrights">{{ store.settings.branding.copyrights | safe }}</span>
                    </div>

                    <div class="vat-icon">
                        <a {% if store.settings.general.tax_settings.tax_registration_certificate %}
                            href="{{ store.settings.general.tax_settings.tax_registration_certificate }}"
                            target="_blank" {% endif %}>
                            <img src="{{ 'vat-certificate.png' | asset_url }}" loading="lazy" alt="" width="auto"
                                height="40">
                        </a>
                    </div>

                    <a href="https://eauthenticate.saudibusiness.gov.sa/certificate-details/{{ store.settings.contact.business_center }}"
                        target="_blank" class="maroof-icon" style="text-align: center; color: inherit;">
                        <img src="{{ 'business_center.png' | asset_url }}" loading="lazy" alt="" width="auto"
                            height="30">
                        <div>{{ store.settings.contact.business_center }}</div>
                    </a>

                    <div class="vat-number">
                        <span>{{ _("The VAT number:") }}</span>
                        <span>{{ store.settings.general.tax_settings.tax_number }}</span>
                    </div>

                    <div class="maroof-icon">
                        <span>{{ _("The commercial register number:") }}</span>
                        <span>{{ store.settings.general.commercial_registration_number }}</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

