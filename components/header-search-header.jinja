                                <div class="gift-popover-body">
                                    <img src="{{ 'gift-popover-icon.svg' | asset_url }}" width="24" height="24" />
                                    <p class="h6 my-2">
                                        {{ _('Send as gift') }}
                                    </p>
                                    <button class="btn round primary d-block">
                                        <a href="/cart" class="no-border d-block">
