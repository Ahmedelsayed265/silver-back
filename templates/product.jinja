{% extends "layout.jinja" %}

{% block header %} {% include 'header.jinja' %} {% endblock %}

{% block top_links %}
<link rel="stylesheet" type="text/css" href="{{ 'toastr.min.css' | asset_url }}" />
<link rel="stylesheet" type="text/css" href="{{ 'ekko-lightbox.css' | asset_url }}" />
<link rel="stylesheet" type="text/css" href="{{ 'product-details.css' | asset_url }}" />
{% endblock %}

{% block main_content %}
<section class="breadcrumb-section">
    <nav aria-label="breadcrumb" class="container-fluid">
        <ol class="breadcrumb image_breadcrumb">
            <div class="tetx_breadcrumb">
                <div style="display: flex;align-items: flex-start;">
                    <li class="breadcrumb-item pageed" aria-current="page">
                        <a href="/">{{ _("Home") }}</a>
                    </li>
                    {% if product.categories and product.categories|count > 0 %}
                    <li class="breadcrumb-item active">
                        <span>
                            {% set firstCategory = product.categories|first %}
                            <a href="{{ firstCategory.url }}">{{ firstCategory.name }}</a>
                        </span>
                    </li>
                    {% endif %}
                </div>
            </div>
        </ol>
    </nav>
</section>

<section class="product products-details-page">
    <div class="container-fluid pb-5">
        <section class="products-details mb-5">
            <div class="rowled">
                <div class="rowled-images">
                    <!--GALLERY-->
                    <div id="wrap">
                        <div class="row">
                            <div class="col-12 col-product-image-wrapper">
                                <div class="topic-mobile">
                                    <h1 class="title-name">{{ product.name | safe }}</h1>
                                    {% if product.rating and product.rating.total_count > 0 %}
                                    <div class="first-rating">
                                        {% set rating = product.rating.average %}
                                        {% include 'components/rating-stars.jinja' %}
                                        <span class="product-card-rating-count">{{ product.rating.total_count
                                            }}&nbsp;{{ _("product review") }}</span>
                                    </div>
                                    {% endif %}
                                </div>

                                <!-- Carousel -->
                                <div
                                    class="product-images-carousel product-images-carousel-init {% if product.selected_product.media|count <= 0 %}d-none{% endif %}">
                                    <div class="">
                                        <div id="product-images" class="product-images slide gallery">
                                            {% if product.sale_price
                                            and product.purchase_restrictions.sale_price_period_end is defined
                                            and product.purchase_restrictions.sale_price_period_end %}
                                            <div class="countdown-card"
                                                data-start="{{ product.purchase_restrictions.sale_price_period_start }}"
                                                data-end="{{ product.purchase_restrictions.sale_price_period_end }}">
                                                <div class="countdown-time">
                                                    <div>
                                                        <div class="days count">00</div>
                                                        <span>يوم</span>
                                                    </div>
                                                    <div>
                                                        <div class="hours count">00</div>
                                                        <span>ساعة</span>
                                                    </div>
                                                    <div>
                                                        <div class="minutes count">00</div>
                                                        <span>دقيقة</span>
                                                    </div>
                                                    <div>
                                                        <div class="seconds count">00</div>
                                                        <span>ثانية</span>
                                                    </div>
                                                </div>
                                            </div>
                                            {% endif %}
                                            <div id="product-images-slick">
                                                {% for image in product.selected_product.media %}
                                                <div>
                                                    <a class="image-link"
                                                        style="display:block; width: 100%; height: 100%;">
                                                        <img loading="lazy" src="{{ image.image.full_size }}"
                                                            width="359" height="359" class="carousel-img"
                                                            alt="{{ image.alt_text }}">
                                                        {% if image.provider and image.link %}
                                                        <img id="main-video-icon" class="play-icon"
                                                            src="{{ 'video-play.svg' | asset_url }}" alt="play"
                                                            width="25" height="25"
                                                            onClick="showIframe(this, '{{ image.link }}')" />
                                                        {% endif %}
                                                    </a>
                                                    {% if image.provider and image.link %}
                                                    <div class="iframe-video pt-1 d-none">
                                                        <a id="iframe-close-btn" type="button"
                                                            class="text-white btn btn-none grow"
                                                            onClick="hideIframe(this)">
                                                            X
                                                        </a>
                                                        <iframe width="100%" height="100%" src="" frameborder="0"
                                                            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                                            allowfullscreen style="max-width: 100%">
                                                        </iframe>
                                                    </div>
                                                    {% endif %}
                                                </div>
                                                {% endfor %}
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                {% if request.is_mobile() == true %}
                                <div
                                    class="row lg-thumbs d-lg-flex product-images-carousel-thumbs {% if product.selected_product.media|count <= 1 %}d-none-important{% endif %}">
                                    {% for image in product.selected_product.media %}
                                    <div class="col-3">
                                        <div class="box-1-1">
                                            <div class="content">
                                                <a class="d-flex align-items-center justify-content-center thumb-image-a"
                                                    data-index="{{ loop.index0 }}" style="width: 100%; height: 100%;">
                                                    <img src="{{ image.image.medium }}" data-index="{{ loop.index0 }}"
                                                        width="100" height="100">
                                                    {% if image.provider and image.link %}
                                                    <img id="video-play-icon" class="play-icon"
                                                        src="{{ 'video-play.svg' | asset_url }}" alt="play"
                                                        data-index="{{ loop.index0 }}" width="25" height="25" />
                                                    {% endif %}
                                                </a>
                                            </div>
                                        </div>
                                    </div>
                                    {% endfor %}
                                </div>
                                {% endif %}

                                <!-- No image -->
                                <div
                                    class="box-1-1 product-images-empty {% if product.selected_product.media|count > 0 %}d-none{% endif %}">
                                    <div class="content">
                                        <div class="d-flex" style="width: 100%; height: 100%;">
                                            <img src="{{ 'product-img.svg' | asset_url }}" width="100%" height="auto" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div
                    class="col-product-info {% if product.selected_product.media|count <= 1 %}col-product-info-single-image{% endif %}">
                    <section>
                        {% if product.badge %}
                        {% include 'vitrin:products/badge.jinja' %}
                        {% endif %}
                        <div class="prift-topic">
                            <h1 class="title-name">{{ product.name | safe }}</h1>
                            <div class="d-flex">
                                <div class="price-filx">
                                    <h2 class="product-formatted-price theme-text-primary">
                                        {% if product.selected_product.formatted_sale_price %}
                                        {{ product.selected_product.formatted_sale_price }}
                                        {% else %}
                                        {{ product.selected_product.formatted_price }}
                                        {% endif %}
                                    </h2>
                                    <p>
                                        <del class="product-formatted-price-old">
                                            {% if product.selected_product.formatted_sale_price %}
                                            {{ product.selected_product.formatted_price }}
                                            {% endif %}
                                        </del>
                                    </p>
                                </div>
                            </div>

                            <!-- Button trigger modal -->
                            <div class="total-options">
                                {% if product.rating and product.rating.total_count > 0 %}
                                <div class="first-rating">
                                    {% set rating = product.rating.average %}
                                    {% include 'components/rating-stars.jinja' %}
                                    <span class="product-card-rating-count">{{ product.rating.total_count }}&nbsp;{{
                                        _("product review") }}</span>
                                </div>
                                {% endif %}

                                <div class="wishlists-local">
                                    {% if store.settings.products.wishlist_enabled %}
                                    <span class="add-to-wishlist" data-wishlist-id="{{ product.id }}">
                                        <span zid-visible-customer="true">
                                            <button zid-visible-wishlist="{{ product.id }}"
                                                class="icon-heart-mask filled"
                                                onclick="addToWishlist(this, '{{ product.id }}')"></button>
                                            <button zid-hidden-wishlist="{{ product.id }}" class="icon-heart-mask"
                                                onclick="addToWishlist(this, '{{ product.id }}')"></button>
                                        </span>

                                        <a zid-visible-guest="true" class="icon-heart-mask"
                                            href="/auth/login?redirect_to={{ session.url.path }}"
                                            onclick="event.preventDefault(); handleLoginAction('', false); return false;"></a>
                                        <img class="loader d-none" src="{{ 'spinner.gif' | asset_url }}" width="20"
                                            height="20" />
                                    </span>
                                    {% endif %}
                                    <span>{{ _("Wishlist") }}</span>
                                </div>

                                <button type="button" class="btn btn-primary btn-lg" onclick="shareProduct()">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24"
                                        color="currentColor" fill="none" stroke="#141B34" stroke-width="1.5">
                                        <path
                                            d="M21 6.5C21 8.15685 19.6569 9.5 18 9.5C16.3431 9.5 15 8.15685 15 6.5C15 4.84315 16.3431 3.5 18 3.5C19.6569 3.5 21 4.84315 21 6.5Z" />
                                        <path
                                            d="M9 12C9 13.6569 7.65685 15 6 15C4.34315 15 3 13.6569 3 12C3 10.3431 4.34315 9 6 9C7.65685 9 9 10.3431 9 12Z" />
                                        <path
                                            d="M21 17.5C21 19.1569 19.6569 20.5 18 20.5C16.3431 20.5 15 19.1569 15 17.5C15 15.8431 16.3431 14.5 18 14.5C19.6569 14.5 21 15.8431 21 17.5Z" />
                                        <path d="M8.72852 10.7495L15.2285 7.75M8.72852 13.25L15.2285 16.2495" />
                                    </svg>
                                    <h4 class="product-title">{{ _("product share") }}</h4>
                                </button>
                            </div>
                        </div>

                        <div class="d-flex flex-column flex-lg-row product-features">
                            {% if product.sold_products_count %}
                            <div class="product-count d-flex align-items-center">
                                <span class="icon-military_tech" style="color: #FFCF57; font-size: 16px"></span>&nbsp;
                                <span class="lang">{{ _("Sold more than %s times") |
                                    format(product.sold_products_count) }}</span>
                            </div>
                            {% elif product.selected_product.sold_products_count %}
                            <div class="product-count d-flex align-items-center">
                                <span class="icon-military_tech" style="color: #FFCF57; font-size: 16px"></span>&nbsp;
                                <span class="lang">{{ _("Sold more than %s times") |
                                    format(product.selected_product.sold_products_count) }}</span>
                            </div>
                            {% endif %}

                            {% if product.low_stock_quantity %}
                            <div class="low-quantity-section d-inline-block">
                                <span class="icon-flag_black" style="color: #EC5550; font-size: 16px"></span>&nbsp;
                                <span class="low-quantity">{{ _("Remaining %s only") |
                                    format(product.low_stock_quantity) }}</span>
                            </div>
                            {% endif %}

                            {% if product.bundle_offer %}
                            <div class="bundle-offer-section">
                                <span class="icon-gift" style="color: red; font-size: 14px"></span>&nbsp;
                                <span class="bundle-offer-title">{{ product.bundle_offer.name }}</span>
                            </div>
                            {% endif %}

                            {% if product.extra_bundle_offers %}
                            {% for bundle_offer in product.extra_bundle_offers %}
                            <div class="bundle-offer-section">
                                <span class="icon-gift" style="color: red; font-size: 14px"></span>&nbsp;
                                <span class="bundle-offer-title">{{ bundle_offer.name }}</span>
                            </div>
                            {% endfor %}
                            {% endif %}
                        </div>
                    </section>

                    <div class="div-product-sku {% if not product.selected_product.sku %}d-none{% endif %}">
                        <h4 class="product-title">{{ _("product sku") }} : </h4>
                        <div class="product-sku">
                            {{ product.selected_product.sku }}
                        </div>
                    </div>

                    <div class="div-product-weight {% if not product.selected_product.weight.value %}d-none{% endif %}">
                        <h4 class="product-title">{{ _("Weight") }} : </h4>
                        <div class="product-weight">
                            {{ product.selected_product.weight.value }}&nbsp;{{ product.selected_product.weight.unit
                            }}
                        </div>
                    </div>

                    <form id="product-form">
                        <input id="product-id" name="product_id" type="hidden"
                            value="{{ product.selected_product.id }}">

                        <div class="size-box">
                            {% include 'vitrin:products/variants_list.jinja' %}

                            <!-- new custom fields update -->
                            {% if product.has_custom_input_fields %}
                            {% include 'vitrin:products/custom_input_fields.jinja' %}
                            {% endif %}
                        </div>

                        <div
                            class="section-out-of-stock-notify-me {% if not product.selected_product.in_stock %}d-block{% else %}d-none{% endif %}">
                            <div>
                                <h4 class="product-title">{{ _("This product is out of stock") }}</h4>
                                <div class="notify-me-form-wrapper">
                                    <input type="hidden" class="send-notify-product-id"
                                        value="{{ product.selected_product.id }}">
                                    <div class="form-group form-notify-me">
                                        <h4>{{ _("Notify me when available") }}</h4>

                                        <input class="form-control send-notify-name" value="" type="text"
                                            placeholder="{{ _('notify me hint name') }}" />
                                        <input class="form-control send-notify-email" type="email" value=""
                                            placeholder="{{ _('notify me hint') }}" />
                                        <div class="d-flex form-notify-me-phone-row">
                                            <input class="form-control send-notify-country-key" type="number"
                                                placeholder="966" maxlength="4" />
                                            <input class="form-control send-notify-phone" type="number" value=""
                                                placeholder="{{ _('notify me hint mobile') }}" maxlength="10" />
                                        </div>
                                        <div class="form-notify-me-submit-button-row">
                                            <button type="button" class="btn btn-primary btn-send-notify"
                                                onclick="sendProductNotifyMe()">
                                                <img class="send-notify-progress d-none"
                                                    src="{{ 'spinner.gif' | asset_url }}" width="15" height="15" />
                                                {{ _("Send") }}
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div>
                            {% include 'vitrin:products/loyalty_points_widget.jinja' %}
                        </div>

                        <div>
                            {% include 'vitrin:products/payment_widgets.jinja' %}
                        </div>
                        <div class="quantity-add-to">

                            <div class="product-buttons {% if product.selected_product.out_of_stock %}d-none{% else %}d-flex{% endif %}"
                                style="flex-direction: column; gap: 4px;">
                                <div class="d-flex align-center" style="gap: 8px;">
                                    {% if product.selected_product.is_infinite or product.selected_product.quantity > 0
                                    %}
                                    <div class="price-count">
                                        {% if product.selected_product.is_infinite or product.selected_product.quantity
                                        > 0
                                        %}
                                        <div class="select-quantity-div">
                                            <div class="form-group">
                                                <div class="qty-input counter-group">
                                                    <button class="qty-count qty-count--minus " data-action="minus"
                                                        type="button">
                                                        <svg xmlns="http://www.w3.org/2000/svg" version="1.1"
                                                            xmlns:xlink="http://www.w3.org/1999/xlink" width="16"
                                                            height="16" x="0" y="0" viewBox="0 0 121.805 121.804"
                                                            style="enable-background:new 0 0 512 512"
                                                            xml:space="preserve" class="">
                                                            <g>
                                                                <path
                                                                    d="M7.308 68.211h107.188a7.309 7.309 0 0 0 7.309-7.31 7.308 7.308 0 0 0-7.309-7.309H7.308a7.31 7.31 0 0 0 0 14.619z"
                                                                    fill="#000000" opacity="1" data-original="#000000">
                                                                </path>
                                                            </g>
                                                        </svg>
                                                    </button>
                                                    <input class="product-qty " id="product-quantity" type="number"
                                                        name="quantity" min="1" max="100" value="1">
                                                    <button class="qty-count qty-count--add" data-action="add"
                                                        type="button">
                                                        <svg xmlns="http://www.w3.org/2000/svg" version="1.1"
                                                            xmlns:xlink="http://www.w3.org/1999/xlink" width="14"
                                                            height="14" x="0" y="0" viewBox="0 0 426.667 426.667"
                                                            style="enable-background:new 0 0 512 512"
                                                            xml:space="preserve">
                                                            <g>
                                                                <path
                                                                    d="M405.332 192H234.668V21.332C234.668 9.559 225.109 0 213.332 0 201.559 0 192 9.559 192 21.332V192H21.332C9.559 192 0 201.559 0 213.332c0 11.777 9.559 21.336 21.332 21.336H192v170.664c0 11.777 9.559 21.336 21.332 21.336 11.777 0 21.336-9.559 21.336-21.336V234.668h170.664c11.777 0 21.336-9.559 21.336-21.336 0-11.773-9.559-21.332-21.336-21.332zm0 0"
                                                                    fill="#000000" opacity="1" data-original="#000000">
                                                                </path>
                                                            </g>
                                                        </svg>
                                                    </button>
                                                </div>
                                            </div>
                                        </div>
                                        {% endif %}
                                    </div>
                                    {% endif %}

                                    <button class="btn btn-add-to-cart" type="button" onclick="productAddToCart()">
                                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24"
                                            height="24" color="currentColor" fill="none" stroke="#FFFFFF"
                                            stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                            <path
                                                d="M8 7H16C17.8856 7 18.8284 7 19.4142 7.58579C20 8.17157 20 9.11438 20 11V15C20 18.2998 20 19.9497 18.9749 20.9749C17.9497 22 16.2998 22 13 22H11C7.70017 22 6.05025 22 5.02513 20.9749C4 19.9497 4 18.2998 4 15V11C4 9.11438 4 8.17157 4.58579 7.58579C5.17157 7 6.11438 7 8 7Z" />
                                            <path d="M16 9.5C16 5.63401 14.2091 2 12 2C9.79086 2 8 5.63401 8 9.5" />
                                        </svg>
                                        <img class="add-to-cart-progress d-none" src="{{ 'spinner.gif' | asset_url }}"
                                            width="25" height="25" />
                                        <span>{{ _("add to cart") }}</span>
                                    </button>

                                    <!-- Checkout dialog -->

                                </div>

                                {% include 'vitrin:checkout/checkout_dialog.jinja' %}

                                <button class="btn btn-buy-now " type="button" onclick="zidProductBuyNow()"
                                    style="margin-inline-start: 10px;">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="24" height="24"
                                        color="#ffffff" fill="none" stroke="#ffffff" stroke-width="1.5"
                                        stroke-linecap="round" stroke-linejoin="round">
                                        <path
                                            d="M14 3H5C3.89543 3 3 3.89543 3 5C3 6.10457 3.89543 7 5 7H18C18 6.07003 18 5.60504 17.8978 5.22354C17.6204 4.18827 16.8117 3.37962 15.7765 3.10222C15.395 3 14.93 3 14 3Z" />
                                        <path
                                            d="M3 5V15C3 17.8284 3 19.2426 3.87868 20.1213C4.75736 21 6.17157 21 9 21H15C17.8284 21 19.2426 21 20.1213 20.1213C21 19.2426 21 17.8284 21 15V13C21 10.1716 21 8.75736 20.1213 7.87868C19.2426 7 17.8284 7 15 7H7" />
                                        <path
                                            d="M21 12H19C18.535 12 18.3025 12 18.1118 12.0511C17.5941 12.1898 17.1898 12.5941 17.0511 13.1118C17 13.3025 17 13.535 17 14C17 14.465 17 14.6975 17.0511 14.8882C17.1898 15.4059 17.5941 15.8102 18.1118 15.9489C18.3025 16 18.535 16 19 16H21" />
                                    </svg>
                                    <img class="buy-now-progress d-none" src="{{ 'spinner.gif' | asset_url }}"
                                        width="25" height="25" />

                                    <span>{{ _("Buy now") }}</span>
                                </button>

                                <div>
                                    {% include 'vitrin:checkout/apple-pay-quick-checkout.jinja' %}
                                </div>
                            </div>
                        </div>
                    </form>

                    {% if product.description %}
                    <button class="btn btn-primary btn-collabs" type="button" data-toggle="collapse"
                        data-target="#collapseExample" aria-expanded="true" aria-controls="collapseExample">
                        <section id="product-description">
                            <div class="description-title">
                                {{ _("product description") }}
                            </div>

                            <i class="fa-solid fa-plus"></i>
                            <i class="fa-solid fa-minus"></i>
                        </section>
                    </button>
                    {% endif %}

                    {% if product.description %}
                    <div class="collapse show" id="collapseExample">
                        <div class="well">
                            <section id="product-description" class="mt-5">
                                <div class="description-paragrah text-justify description-text-clear">
                                    {{ product.description | safe }}
                                </div>
                            </section>
                        </div>
                    </div>
                    {% endif %}

                    <section class="mt-3 margin-inline-start: 8px; color: rgb(85, 85, 85); font-weight: normal;mb-2">
                        <div class="cart-product">
                            {% set currentProductId = product.id|trim|striptags %}

                            {% if settings.detail_details %}
                            {% for item in settings.detail_details %}
                            {% if item.product and item.product.id %}
                            {% set itemProductId = item.product.id|trim|striptags %}
                            {% if currentProductId == itemProductId %}
                            <section class="product-detail-section mt-5">
                                <div class="content">
                                    <div class="section-title">{{ item.topic }}</div>
                                </div>
                                {% if item.category %}
                                <div class="containered mt-4">
                                    <div class="category-products slick-slider-block"
                                        data-cat-id="{{ item.category.id }}" id="category-products-{{ loop.index }}"
                                        style="position: relative;">
                                        <div class="loading-spinner text-center mt-3">
                                            <span>{{ _("loading") }}</span>
                                        </div>
                                    </div>
                                </div>
                                {% endif %}
                            </section>
                            {% endif %}
                            {% endif %}
                            {% endfor %}
                            {% endif %}

                            <!-- Script section for category products - FIXED -->
                            <script>
                                document.addEventListener('DOMContentLoaded', function () {
                                    console.log('DOM loaded - starting category products fetch');

                                    const sections = document.querySelectorAll('.category-products');
                                    console.log('Found category sections:', sections.length);

                                    sections.forEach(container => {
                                        const loader = container.querySelector('.loading-spinner');
                                        const categoryId = container.getAttribute('data-cat-id');

                                        console.log('Processing category container:', { categoryId, container });

                                        if (!categoryId) {
                                            console.warn('No category ID found for container');
                                            return;
                                        }

                                        // Show loader
                                        if (loader) loader.style.display = 'block';

                                        // Fetch products from category
                                        zid.store.product.fetchAll(categoryId, { per_page: 8 }).then(function (response) {
                                            console.log('API Response for category', categoryId, ':', response);

                                            if (loader) loader.style.display = 'none';

                                            if (response.status === 'success' && response.data && response.data.products) {
                                                const products = response.data.products.data || [];
                                                console.log('Products loaded:', products.length);

                                                if (!products.length) {
                                                    container.innerHTML = '<p class="text-muted text-center">لا توجد منتجات في هذا التصنيف حالياً.</p>';
                                                    return;
                                                }

                                                // Create slider wrapper
                                                const sliderWrapper = document.createElement('div');
                                                sliderWrapper.className = 'products-slider related-products-slider';
                                                container.appendChild(sliderWrapper);

                                                products.forEach(p => {
                                                    // Get product image
                                                    const img = (p.images && p.images.length > 0 &&
                                                        (p.images[0].image?.full_size ||
                                                            p.images[0].image?.large ||
                                                            p.images[0].image?.medium ||
                                                            p.images[0].image?.small ||
                                                            p.images[0].url))
                                                        || 'https://xtzny4.zid.store/assets/imgs/placeholder.png';

                                                    const hasDiscount = p.sale_price && p.sale_price < p.price;
                                                    const formattedPrice = hasDiscount
                                                        ? `<div class="section-product-price">
                                                                    <div class="product-price"><span>${p.formatted_sale_price}</span></div>
                                                                    <div class="product-prev-price"><span>${p.formatted_price}</span></div>
                                                               </div>`
                                                        : `<div class="product-price section-product-price theme-title-primary">
                                                                    <span>${p.formatted_price}</span>
                                                               </div>`;

                                                    const html = `
                                                            <div class="prod-col">
                                                                <div class="protected">
                                                                    <div class="main_product" style="width: 100%; height: 100%;">
                                                                        <div class="imaged">
                                                                            <a href="${p.html_url}">
                                                                                <img class="image-static" src="${img}" alt="${p.name}" loading="lazy" width="250" height="250">
                                                                            </a>
                                                                            ${!p.is_infinite && p.quantity <= 0 ? `<small>غير متوفر حالياً</small>` : ''}
                                                                        </div>
                                                                    </div>
                                                                    
                                                                    <div class="product-content">
                                                                        ${p.categories && p.categories.length ? `
                                                                            <div class="categorey-title">
                                                                                <span><a href="${p.categories[p.categories.length - 1].url}">${p.categories[p.categories.length - 1].name}</a></span>
                                                                            </div>` : ''
                                                        }
                                                                        
                                                                        <a href="${p.html_url}">
                                                                            <div class="product-title"><h3>${p.name}</h3></div>
                                                                        </a>
                                                                        
                                                                        <div class="proded">
                                                                            <div style="text-align:center" class="added">
                                                                                ${!p.is_infinite && p.quantity <= 0 ? `
                                                                                    <a class="btn btn-primary btn-product-card-out-of-stock" href="${p.html_url}">
                                                                                        <span>{{ _('notify me if available') }}</span>
                                                                                    </a>`
                                                            : (p.has_options || p.has_fields) ? `
                                                                                    <a class="btn btn-primary btn-product-card-select-variant" href="${p.html_url}">
                                                                                        <span>{{ _('add to cart') }}</span>
                                                                                    </a>`
                                                                : `
                                                                                    <a href="javascript:void(0)" class="btn btn-primary product-card-add-to-cart" onclick="productCartAddToCart(this,'${p.id}')">
                                                                                        <img class="add-to-cart-progress d-none" src="{{ 'spinner.gif' | asset_url }}" width="20" height="20"/>
                                                                                        <span>{{ _('add to cart') }}</span>
                                                                                    </a>`
                                                        }
                                                                        </div>
                                                                        
                                                                        <div class="product-crd-spec">
                                                                            ${formattedPrice}
                                                                        </div>
                                                                    </div>
                                                                </div>
                                                            </div>
                                                        `;
                                                    sliderWrapper.insertAdjacentHTML('beforeend', html);
                                                });

                                                // Initialize slider after products added
                                                setTimeout(() => initProductSlider(sliderWrapper), 100);
                                            } else {
                                                container.innerHTML = '<p class="text-danger text-center">تعذر تحميل المنتجات.</p>';
                                            }
                                        }).catch(err => {
                                            console.error('API Error for category', categoryId, ':', err);
                                            if (loader) loader.style.display = 'none';
                                            container.innerHTML = '<p class="text-danger text-center">حدث خطأ أثناء تحميل المنتجات.</p>';
                                        });
                                    });

                                    function initProductSlider(sliderElement) {
                                        console.log('Initializing product slider for:', sliderElement);

                                        var screenWidth = window.innerWidth;
                                        var editingMode = {% if store.editing_mode %} true{% else %} false{% endif %};

                                    // Check if there are elements in the slider
                                    const slideCount = sliderElement.querySelectorAll('.prod-col').length;
                                    console.log('Slide count:', slideCount);

                                    if (slideCount <= 1) {
                                        console.log('Not enough slides for slider');
                                        return;
                                    }

                                    if (screenWidth >= 0 || editingMode) {
                                        // Clean up any previous Slick initialization
                                        if ($(sliderElement).hasClass('slick-initialized')) {
                                            $(sliderElement).slick('unslick');
                                        }

                                        // Setup Slick slider
                                        try {
                                            $(sliderElement).slick({
                                                slidesToShow: Math.min(4, slideCount),
                                                slidesToScroll: 1,
                                                infinite: false,
                                                autoplay: false,
                                                arrows: false,
                                                dots: false,
                                                rtl: !(window.appDirection === 'ltr'),
                                                adaptiveHeight: true,
                                                nextArrow: '<button class="slick-next slick-arrow" aria-label="Next" type="button"><span class="icon-keyboard_arrow_right"></span></button>',
                                                prevArrow: '<button class="slick-prev slick-arrow" aria-label="Previous" type="button"><span class="icon-keyboard_arrow_left"></span></button>',
                                                responsive: [
                                                    {
                                                        breakpoint: 1400,
                                                        settings: {
                                                            slidesToShow: Math.min(3, slideCount),
                                                            slidesToScroll: 1
                                                        }
                                                    },
                                                    {
                                                        breakpoint: 992,
                                                        settings: {
                                                            slidesToShow: Math.min(2.5, slideCount),
                                                            slidesToScroll: 1
                                                        }
                                                    },
                                                    {
                                                        breakpoint: 768,
                                                        settings: {
                                                            slidesToShow: Math.min(2, slideCount),
                                                            slidesToScroll: 1
                                                        }
                                                    },
                                                    {
                                                        breakpoint: 576,
                                                        settings: {
                                                            slidesToShow: Math.min(1.5, slideCount),
                                                            slidesToScroll: 1
                                                        }
                                                    },
                                                    {
                                                        breakpoint: 400,
                                                        settings: {
                                                            slidesToShow: 1,
                                                            slidesToScroll: 1
                                                        }
                                                    }
                                                ]
                                            });
                                            console.log('Slick slider initialized successfully');
                                        } catch (error) {
                                            console.error('Error initializing slick slider:', error);
                                        }
                                    }
                                }
                                });
                            </script>
                        </div>
                    </section>

