    $(document).on('click', '.thumb-image-a, #video-play-icon', function (event) {
        var tarr = event.target;
        var index = $(tarr).attr('data-index') || $(tarr).closest('[data-index]').attr('data-index');

        if ($('#product-images-slick')) {
            $('#product-images-slick').slick('slickGoTo', index, true);
        }
    });

    var initSlick = function (productImages) {
        var screenWidth = window.innerWidth;
        var arrowNextClass =
            window.appDirection === "ltr"
                ? "icon-keyboard_arrow_right"
                : "icon-keyboard_arrow_left";
        var arrowPrevClass =
            window.appDirection === "ltr"
                ? "icon-keyboard_arrow_left"
                : "icon-keyboard_arrow_right";

        if (screenWidth < 992) {
            $("#product-images-slick").slick({
                infinite: false,
                autoplay: false,
                arrows: false,
                dots: productImages.length > 1,
                rtl: !(window.appDirection === "ltr"),
                nextArrow:
                    '<button class="slick-next slick-arrow" aria-label="Next" type="button">' +
                    '<span class="' + arrowNextClass + '"></span></button>',
                prevArrow:
                    '<button class="slick-prev slick-arrow" aria-label="Previous" type="button">' +
                    '<span class="' + arrowPrevClass + '"></span></button>',
                customPaging: function (slider, i) {
                    const item = productImages[i];
                    const thumb = item?.image?.small || item?.image?.medium || item?.image?.large || "";
                    return `<img src="${thumb}" width="45" height="45" style="width:45px;height:45px;object-fit:cover;border-radius:6px;" />`;
                }
            });
        } else {
            renderStaticMedia(productImages);
        }
    };

    function renderStaticMedia(mediaList) {
        const $container = $("#product-images-slick");
        $container.html("");

        mediaList.forEach((item, i) => {
            const isVideo = item.provider && item.link;
            const html = `
                <div class="">
                    <div class="position-relative static-image-entry" data-index="${i}">
                        <img src="${item.image.full_size}" class="carousel-img" alt="${item.alt_text || ""}" width="359" height="359">
                        ${isVideo ? `<img id="main-video-icon" class="play-icon" 
                                src="{{ "video-play.svg" | asset_url }}" 
                                alt="play"
                                width="25"
                                height="25"
                                onclick="toggleStaticIframe(this,'${item.link}')">` : ""}
                        ${isVideo ? `<div class="iframe-video pt-1 d-none">
                                <a id="iframe-close-btn" type="button" class="text-white btn btn-none grow" onclick="hideIframe(this)">X</a>
                                <iframe width="100%" height="400" src="" frameborder="0"
                                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                                    allowfullscreen></iframe>
                            </div>` : ""}
                    </div>
                </div>
            `;
            $container.append(html);
        });
    }

    function toggleStaticIframe(elm, link) {
        let iframeWrapper = $(elm).closest(".content").find(".iframe-video");
        if (!iframeWrapper.length) {
            iframeWrapper = $(elm).closest(".position-relative").find(".iframe-video");
        }
        const iframe = iframeWrapper.find("iframe");

        if (iframeWrapper.hasClass("d-none")) {
            iframeWrapper.removeClass("d-none");
            const src = getIframeLink(link);
            iframe.attr("src", src + "&autoplay=1&mute=1");
        } else {
            iframeWrapper.addClass("d-none");
            iframe.attr("src", "");
        }
    }

    // 🔧 الدالة المصلحة لفتح المودال
    function openImagesModalBySrc(src) {
        var images = (productImages || []).filter(function (it) {
            return !(it.provider && it.link);
        }).map(function (it) {
            return it.image?.full_size || it.image?.large || it.image?.medium || it.image?.small;
        });

        if (!images.length) return;

        var startIndex = images.indexOf(src);
        if (startIndex < 0) startIndex = 0;

        var $slider = $('#product-images-modal-slider');
        var $modal = $('#product-images-modal');

        // تنظيف كامل
        if ($slider.hasClass('slick-initialized')) {
            try { $slider.slick('unslick'); } catch (e) { }
            $slider.removeClass('slick-initialized');
        }
        $slider.html('');
        $slider.off('init afterChange');

        // بناء الـ slides
        for (var i = 0; i < images.length; i++) {
            $slider.append('<div><img src="' + images[i] + '" alt="صورة المنتج ' + (i + 1) + '" width="800" height="800"/></div>');
        }

        var isRTL = !(window.appDirection === 'ltr');
        var arrowNext = isRTL ? 'icon-keyboard_arrow_left' : 'icon-keyboard_arrow_right';
        var arrowPrev = isRTL ? 'icon-keyboard_arrow_right' : 'icon-keyboard_arrow_left';

        var updateProgress = function (idx, total) {
            var pct = ((idx + 1) / total) * 100;
            $('#product-images-modal-progress .fill').css('width', pct + '%');
            $('#modal-slide-counter').text((idx + 1) + ' / ' + total);
        };

        // دالة التهيئة مع recursive check
        var initSlider = function () {
            if (!$slider.length || !$slider.is(':visible')) {
                setTimeout(initSlider, 50);
                return;
            }

            $slider.off('init afterChange');

            if ($slider.hasClass('slick-initialized')) {
                try { $slider.slick('unslick'); } catch (e) { }
                $slider.removeClass('slick-initialized');
            }

            // إخفاء الـ slider أثناء التهيئة لمنع الـ glitch
            $slider.css('visibility', 'hidden');

            $slider.on('init', function (e, slick) {
                updateProgress(slick.currentSlide, slick.slideCount);
                setTimeout(function () {
                    if ($slider.hasClass('slick-initialized')) {
                        try {
                            if (startIndex !== slick.currentSlide) {
                                $slider.slick('slickGoTo', startIndex, true);
                            }
                            $slider.slick('setPosition');
                        } catch (e) { }
                    }
                    // إظهار الـ slider بعد انتهاء التهيئة والانتقال للصورة الصح
                    $slider.css('visibility', 'visible');
                }, 100);
            });

            $slider.on('afterChange', function (e, slick, currentSlide) {
                updateProgress(currentSlide, slick.slideCount);
            });

            try {
                $slider.slick({
                    slidesToShow: 1,
                    slidesToScroll: 1,
                    infinite: false,
                    autoplay: false,
                    arrows: true,
                    dots: false,
                    rtl: isRTL,
                    initialSlide: startIndex,
                    adaptiveHeight: false,
                    nextArrow: '<button class="slick-next modal-arrow" type="button"><span class="' + arrowNext + '"></span></button>',
                    prevArrow: '<button class="slick-prev modal-arrow" type="button"><span class="' + arrowPrev + '"></span></button>'
                });
            } catch (e) {
                console.error('Slick init error:', e);
                $slider.css('visibility', 'visible'); // fallback
            }
        };

        // counter badge
        $modal.find('#modal-slide-counter').remove();
        $modal.find('.modal-body').append('<div id="modal-slide-counter"></div>');

        // إعداد events مرة واحدة فقط
        if (!$modal.data('events-initialized')) {
            $modal.on('hidden.bs.modal', function () {
                if ($slider.hasClass('slick-initialized')) {
                    try { $slider.slick('unslick'); } catch (e) { }
                    $slider.removeClass('slick-initialized');
                }
                $('#product-images-modal-progress .fill').css('width', '0%');
                $slider.html('');
                $slider.css('visibility', 'hidden'); // reset للمرة الجاية
                $slider.off('init afterChange');
                $modal.find('#modal-slide-counter').remove();
            });

            // keyboard navigation
            $(document).on('keydown.productModal', function (e) {
                if (!$modal.hasClass('show') && !$modal.is(':visible')) return;
                if (e.key === 'ArrowLeft') {
                    isRTL ? $slider.slick('slickNext') : $slider.slick('slickPrev');
                } else if (e.key === 'ArrowRight') {
                    isRTL ? $slider.slick('slickPrev') : $slider.slick('slickNext');
                } else if (e.key === 'Escape') {
                    $modal.modal('hide');
                }
            });

            $modal.data('events-initialized', true);
        }

        // فتح المودال
        var wasOpen = $modal.hasClass('show') || $modal.hasClass('in');
        $modal.off('shown.bs.modal.imagesModal');

        if (wasOpen) {
            setTimeout(initSlider, 200);
        } else {
            $modal.on('shown.bs.modal.imagesModal', function () {
                $modal.attr('aria-hidden', 'false');
                setTimeout(initSlider, 150);
            });
            $modal.modal('show');
        }
    }

    const getIframeLink = (videoLink) => {
        const videoIdMatch = videoLink.match(
            /(?:https?:\/\/)?(?:www\.)?(?:youtube\.com\/(?:[^\/\n\s]+\/\S+\/|(?:v|e(?:mbed)?|.*[?&]v=)|shorts\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/
        );
        if (videoIdMatch && videoIdMatch[1]) {
            const videoLinkId = videoIdMatch[1];
            return `https://www.youtube.com/embed/${videoLinkId}?autoplay=1&enablejsapi=1&mute=1&rel=0`;
        }
        return null;
    };

    const showIframe = (elm, imageVideoSrc) => {
        if (window.innerWidth >= 992) return;
        const iframeLink = getIframeLink(imageVideoSrc);
        const iframeElem = $(elm)
            .parent(".image-link")
            .siblings(".iframe-video")
            .children("iframe");
        $(elm).parent(".image-link").siblings(".iframe-video").removeClass("d-none");
        if ($(iframeElem).attr("src") !== iframeLink) {
            $(iframeElem).attr("src", iframeLink);
        }
    };

    const hideIframe = (elm) => {
        if (window.innerWidth >= 992) return;
        $(elm).parent(".iframe-video").addClass("d-none");
        $(elm).siblings("iframe").attr("src", "");
    };

    $('#product-images-slick').on('beforeChange', function (event, slick, currentSlide, nextSlide) {
        const iframeContainers = slick.$slides[currentSlide].querySelector(".iframe-video");
        if (iframeContainers) {
            $(iframeContainers).addClass("d-none");
            $(iframeContainers).find("iframe").attr("src", "");
        }
    });

    $('#product-images-slick').on('afterChange', function (event, slick, currentSlide, nextSlide) {
        const iframeContainers = slick.$slides[currentSlide].querySelector(".iframe-video");
        const playIcon = $(iframeContainers).siblings(".image-link").find("#main-video-icon");
        if (playIcon && playIcon.length) {
            playIcon.click();
        }
    });

    document.addEventListener("DOMContentLoaded", () => {
        setTimeout(() => {
            const activeSlide = $("#product-images-slick .slick-slide.slick-active .image-link");
            const playIcon = activeSlide.find("#main-video-icon");
            if (playIcon && playIcon.length) {
                playIcon.click();
            }
        }, 250);
    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        // Select all counter groups
        const counterGroups = document.querySelectorAll('.counter-group');

        // Loop through each group
        counterGroups.forEach(group => {
            const minusButton = group.querySelector('.qty-count--minus');
            const addButton = group.querySelector('.qty-count--add');
            const input = group.querySelector('.product-qty');

            // Function to update the input value
            function updateValue(action) {
                let currentValue = parseInt(input.value);
                const min = parseInt(input.min) || 0; // Default min to 0 if not set
                const max = parseInt(input.max) || Infinity; // Default max to Infinity if not set

                if (action === 'add' && currentValue < max) {
                    input.value = currentValue + 1;
                } else if (action === 'minus' && currentValue > min) {
                    input.value = currentValue - 1;
                }
            }

            // Event listeners for the buttons
            minusButton.addEventListener('click', function () {
                updateValue('minus');
            });

            addButton.addEventListener('click', function () {
                updateValue('add');
            });
        });
    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const countdowns = document.querySelectorAll(".countdown-card");

        countdowns.forEach(container => {
            let start = new Date(container.dataset.start).getTime();
            const end = new Date(container.dataset.end).getTime();
            const now = new Date().getTime();

            if (isNaN(start)) {
                start = now;
            }
            if (isNaN(end) || now > end) {
                return;
            }

            if (isNaN(start) || isNaN(end) || now < start || now > end) {
                return;
            }

            const d = container.querySelector(".days");
            const h = container.querySelector(".hours");
            const m = container.querySelector(".minutes");
            const s = container.querySelector(".seconds");

            function updateCountdown() {
                const current = new Date().getTime();
                const diff = end - current;

                if (diff <= 0) {
                    container.innerHTML = "<div class='expired-offer'>انتهى العرض</div>";
                    return;
                }

                const days = Math.floor(diff / (1000 * 60 * 60 * 24));
                const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((diff % (1000 * 60)) / 1000);

                d.textContent = String(days).padStart(2, "0");
                h.textContent = String(hours).padStart(2, "0");
                m.textContent = String(minutes).padStart(2, "0");
                s.textContent = String(seconds).padStart(2, "0");
            }

            updateCountdown();
            setInterval(updateCountdown, 1000);
        });
    });
</script>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        var productData = {{ product| tojson
    }};
    console.log('Product variants data:', productData.variants);

    if (!productData.variants) return;

    document.querySelectorAll("#product-variants-options li").forEach(function (li) {
        var value = li.getAttribute("value")?.trim();
        if (!value) return;

        var matched = productData.variants.find(v => {
            if (!v.attributes) return false;
            if (Array.isArray(v.attributes)) {
                return v.attributes.some(attr => attr.value === value);
            } else {
                return Object.values(v.attributes).includes(value);
            }
        });

        if (matched) {
            if (matched.images && matched.images.length > 0) {
                var imgSrc = matched.images[0].image?.medium || matched.images[0].image?.full_size;
                if (imgSrc) {
                    var imgEl = document.createElement("img");
                    imgEl.src = imgSrc;
                    imgEl.alt = value;
                    imgEl.loading = "lazy";
                    imgEl.width = 50;
                    imgEl.height = 50;
                    imgEl.style.width = "100%";
                    imgEl.style.height = "100%";
                    imgEl.style.objectFit = "contain";

                    var span = li.querySelector("span");
                    if (span) span.style.display = "none";

                    li.prepend(imgEl);
                    li.style.display = "flex";
                    li.style.alignItems = "center";
                    li.style.justifyContent = "center";
                    li.style.padding = "4px";
                }
            }

            if (matched.out_of_stock || matched.quantity === 0) {
                li.classList.add("out-of-stock-option");
                li.style.pointerEvents = "none";
                li.style.opacity = "0.4";
                li.style.filter = "grayscale(1)";
            }
        }
    });

    const updateLabelValues = () => {
        document.querySelectorAll("#product-variants-options .form-group").forEach(group => {
            const label = group.querySelector("label");
            const active = group.querySelector("li.active span");
            if (label && active) {
                let valueSpan = label.querySelector(".selected-value");
                if (!valueSpan) {
                    valueSpan = document.createElement("span");
                    valueSpan.className = "selected-value";
                    valueSpan.style.marginInlineStart = "4px";
                    valueSpan.style.color = "#555";
                    valueSpan.style.fontWeight = "normal";
                    label.appendChild(valueSpan);
                }
                valueSpan.textContent = active.textContent.trim();
            }
        });
    };

    updateLabelValues();

    document.querySelectorAll("#product-variants-options li").forEach(li => {
        li.addEventListener("click", () => setTimeout(updateLabelValues, 150));
    });
});
</script>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        function removeLazyFromFirstCarouselImages() {
            const imgs = document.querySelectorAll('.carousel-img');
            imgs.forEach((img, i) => {
                if (i < 4) {
                    img.removeAttribute('loading');
                    img.removeAttribute('fetchpriority');
                }
            });
        }
        removeLazyFromFirstCarouselImages();
        const productsList = document.getElementById('products-list');
        if (productsList) {
            const observer = new MutationObserver(() => removeLazyFromFirstCarouselImages());
            observer.observe(productsList, { childList: true, subtree: true });
        }
    });

    const shareProduct = async () => {
        const title = document.querySelector('h1.product-title')?.textContent?.trim() || '';
        const url = window.location.href;
        const text = title ? `شاهد هذا المنتج: ${title}` : 'شاهد هذا المنتج';
        if (navigator.share) {
            try {
                await navigator.share({ title, text, url });
            } catch (err) {
                console.warn('Web Share API failed:', err);
                fallbackCopy(url);
            }
        } else {
            fallbackCopy(url);
        }
    };

    const fallbackCopy = (url) => {
        if (navigator.clipboard && window.isSecureContext) {
            navigator.clipboard.writeText(url).then(() => {
                alert('تم نسخ الرابط إلى الحافظة');
            }).catch(() => {
                promptCopy(url);
            });
        } else {
            promptCopy(url);
        }
    };

    const promptCopy = (url) => {
        const result = prompt('انسخ الرابط:', url);
        if (result === null) {
            return;
        }
    };
</script>
