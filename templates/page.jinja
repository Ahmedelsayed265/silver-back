<!-- Gallery JavaScript -->
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const arrowNextClass = (window.appDirection === 'ltr') ? 'icon-keyboard_arrow_right' : 'icon-keyboard_arrow_left';
        const arrowPrevClass = (window.appDirection === 'ltr') ? 'icon-keyboard_arrow_left' : 'icon-keyboard_arrow_right';

        // Initialize card sliders
        function initCardSliders() {
            document.querySelectorAll('.specialpage-card-slider').forEach(function (el) {
                if (typeof $ !== 'undefined' && $.fn.slick) {
                    $(el).slick({
                        slidesToShow: 1,
                        slidesToScroll: 1,
                        infinite: false,
                        autoplay: false,
                        arrows: false,
                        dots: false,
                        rtl: !(window.appDirection === 'ltr')
                    });

                    // Prevent default click on anchor
                    $(el).closest('a.specialpage_galler').on('click', function (e) {
                        e.preventDefault();
                    });

                    // Handle slide click to open modal
                    $(el).on('click', '.specialpage-slide', function (e) {
                        e.preventDefault();
                        e.stopPropagation();

                        const startIndex = $(this).index();
                        const images = [];

                        // Collect all available images
                        ['image1', 'image2', 'image3', 'image4'].forEach(function (key) {
                            const value = el.getAttribute('data-' + key);
                            if (value && value.trim() !== '') {
                                images.push(value);
                            }
                        });

                        if (images.length) {
                            openBlogImagesModal(images, startIndex);
                        }
                    });
                }
            });
        }

        // Open image modal
        function openBlogImagesModal(images, startIndex) {
            const $modal = $('#product-images-modal');
            const $slider = $('#product-images-modal-slider');
            const $progressFill = $('#product-images-modal-progress .fill');

            // Clean up existing slider
            if ($slider.hasClass('slick-initialized')) {
                $slider.slick('unslick');
            }

            $slider.html('');
            $progressFill.css('width', '0%');

            // Add images to slider
            images.forEach(function (src) {
                $slider.append('<div><img src="' + src + '" alt="image"></div>');
            });

            // Update progress bar
            function updateProgress(idx, total) {
                const pct = total > 0 ? Math.round(((idx + 1) / total) * 100) : 0;
                $progressFill.css('width', pct + '%');
            }

            // Initialize modal slider
            function initSlider() {
                if (typeof $ !== 'undefined' && $.fn.slick) {
                    $slider.slick({
                        slidesToShow: 1,
                        slidesToScroll: 1,
                        infinite: false,
                        autoplay: false,
                        arrows: true,
                        dots: false,
                        rtl: !(window.appDirection === 'ltr'),
                        initialSlide: startIndex,
                        nextArrow: '<button class="slick-next modal-arrow" aria-label="Next" type="button"><span class="' + arrowNextClass + '"></span></button>',
                        prevArrow: '<button class="slick-prev modal-arrow" aria-label="Previous" type="button"><span class="' + arrowPrevClass + '"></span></button>',
                        onInit: function (slick) {
                            updateProgress(slick.currentSlide, slick.slideCount);
                        },
                        afterChange: function (event, slick, currentSlide) {
                            updateProgress(currentSlide, slick.slideCount);
                        }
                    });
                }
            }

            // Modal event handlers
            $modal.off('shown.bs.modal').on('shown.bs.modal', function () {
                setTimeout(initSlider, 10);
            });

            $modal.off('hidden.bs.modal').on('hidden.bs.modal', function () {
                if ($slider.hasClass('slick-initialized')) {
                    $slider.slick('unslick');
                }
                $slider.html('');
                $progressFill.css('width', '0%');
            });

            $modal.modal('show');
        }

        // Initialize on load
        initCardSliders();
    });
</script>

