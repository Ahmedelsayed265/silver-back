                        setTimeout(function () {
                            if (typeof $ !== 'undefined' && $.fn.slick) {
                                $(container).slick({
                                    slidesToShow: 6,
                                    slidesToScroll: 2,
                                    infinite: false,
                                    autoplay: false,
                                    arrows: false,
                                    dots: false,
                                    rtl: !(window.appDirection === 'ltr'),
                                    responsive: [
                                        { breakpoint: 1600, settings: { slidesToShow: 5,   slidesToScroll: 2 } },
                                        { breakpoint: 1400, settings: { slidesToShow: 4.5, slidesToScroll: 1 } },
                                        { breakpoint: 1200, settings: { slidesToShow: 3.5, slidesToScroll: 1 } },
                                        { breakpoint: 992,  settings: { slidesToShow: 2.8, slidesToScroll: 1 } },
                                        { breakpoint: 768,  settings: { slidesToShow: 2.5, slidesToScroll: 1 } },
                                        { breakpoint: 576,  settings: { slidesToShow: 2,   slidesToScroll: 1 } },
                                        { breakpoint: 450,  settings: { slidesToShow: 1.8, slidesToScroll: 1 } },
                                        { breakpoint: 350,  settings: { slidesToShow: 1.5, slidesToScroll: 1 } }
                                    ]
                                });
                            }

                            document.querySelectorAll('#cart-products-slider .product-item').forEach(function (productCard) {
                                var images = productCard.querySelectorAll('.product-image');
                                var interval, isHovering = false;
                                if (images.length > 1) {
                                    productCard.addEventListener('mouseenter', function () {
                                        isHovering = true;
                                        var currentIndex = 0;
                                        interval = setInterval(function () {
                                            if (!isHovering) { clearInterval(interval); return; }
                                            images.forEach(function (img) { img.classList.add('d-none'); });
                                            currentIndex = (currentIndex + 1) % images.length;
                                            images[currentIndex].classList.remove('d-none');
                                        }, 1500);
                                    });
                                    productCard.addEventListener('mouseleave', function () {
                                        isHovering = false;
                                        clearInterval(interval);
                                        images.forEach(function (img) { img.classList.add('d-none'); });
                                        images[0].classList.remove('d-none');
                                    });
                                }
                            });
                        }, 500);

                    } else {
                        var section = document.querySelector('[section-id="cart-products"]');
                        if (section) section.style.display = 'none';
                    }
                })
                .catch(function (error) {
                    console.error('Error fetching cart products:', error);
                    var section = document.querySelector('[section-id="cart-products"]');
                    if (section) section.style.display = 'none';
                });
        }
    });
</script>
