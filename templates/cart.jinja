                            var categoryHtml = '';
                            if (product.categories && product.categories.length > 0) {
                                categoryHtml = '<div class="categorey-title"><span><a href="' + product.categories[0].url + '">' + product.categories[0].name + '</a></span></div>';
                            }

                            var escapedProductName = productName.replace(/"/g, '&quot;').replace(/'/g, '&#39;');

                            var html = '<div class="prod-col">' +
                                '<div class="product-item position-relative ' + (isOutOfStock ? 'product-item-out-of-stock' : '') + '">' +
                                '<div class="d-flex flex-column justify-content-start" style="height: 100%;">' +
                                '<div class="box-1-1"><div class="content">' +
                                '<div class="d-flex justify-content-center" style="width: 100%; height: 100%; position: relative;">' +
                                badgeHtml +
                                '<div class="product-gallery">' +
                                '<img loading="lazy" class="product-image" src="' + mainImage + '" alt="' + escapedProductName + '">' +
                                (secondImage ? '<img loading="lazy" class="product-image d-none" src="' + secondImage + '" alt="' + escapedProductName + '" data-index="1">' : '') +
