            src="{{ image_url(loaderLogoUrl, { h: 175, q: 100 }) }}"
            alt="{{ store.name }}"
            style="width: 200px;"
        />
    </div>
</div>

<!-- Popup Offer Modal -->
    {% if settings.Popup_enable and settings.Popup_title and settings.Popup_image %}
    <div class="section">
        <div class="containers" id="offerContainer" style="display:none;">
            <button class="close-btn" onclick="closeModal()">✕</button>
            <a class="contented" href="{{ settings.Popup_url }}">
                <div class="product-image">
                    <img class="photo_poup" src="{{ settings.Popup_image }}" alt="{{ settings.Popup_title }}"
                        loading="lazy" decoding="async">
                </div>

                <div class="contented-topics">
                    <h1 class="fire-title">
                        {{ settings.Popup_title }}
                        <span class="fire-emoji">🔥</span>
                    </h1>
                    {% if settings.Popup_end_date %}
                    <div class="counter-of-offer" aria-live="polite" role="timer"
                        aria-label="الوقت المتبقي حتى نهاية العرض" data-of-meta="{{ settings.Popup_end_date }}">
                        <div class="timer">
                            <div class="timer-box">
                                <span class="timer-number" id="days">00</span>
                                <span class="timer-label">{{_("Days")}}</span>
                            </div>
                            <div class="timer-box">
                                <span class="timer-number" id="hours">00</span>
                                <span class="timer-label">{{_("Hours")}}</span>
                            </div>
                            <div class="timer-box">
                                <span class="timer-number" id="minutes">00</span>
                                <span class="timer-label">{{_("Minutes")}}</span>
                            </div>
                        </div>
                    </div>
                    {% endif %}
                    <button class="cta-button">{{ settings.Popup_btoned }}</button>
                </div>
            </a>
        </div>

        <script>
            document.addEventListener("DOMContentLoaded", function () {
                const container = document.getElementById("offerContainer");
                const closedTime = localStorage.getItem("offerClosedTime");
                const now = Date.now();

                // الفترة اللي ما يظهرش فيها البانر بعد الإغلاق (بالمللي ثانية)
                const cooldown = 24 * 60 * 60 * 1000; // 24 ساعة

                // لو المستخدم ما قفلش البانر قبل أو انتهت المدة، نظهره
                if (!closedTime || now - closedTime > cooldown) {
                    container.style.display = "block";
                }

                // ====== كود العداد ======
                const counter = document.querySelector('.counter-of-offer');
                if (counter) {
                    const targetDateStr = counter.getAttribute('data-of-meta');
                    if (targetDateStr) {
                        const targetDate = new Date(targetDateStr.replace(/-/g, '/'));

                        function updateTimer() {
                            const now = new Date().getTime();
                            const distance = targetDate - now;
                            const daysEl = document.getElementById('days');
                            const hoursEl = document.getElementById('hours');
                            const minutesEl = document.getElementById('minutes');

                            if (distance <= 0) {
                                daysEl.textContent = '00';
                                hoursEl.textContent = '00';
                                minutesEl.textContent = '00';
                                return;
                            }

                            const days = Math.floor(distance / (1000 * 60 * 60 * 24));
                            const hours = Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                            const minutes = Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));

                            daysEl.textContent = String(days).padStart(2, '0');
                            hoursEl.textContent = String(hours).padStart(2, '0');
                            minutesEl.textContent = String(minutes).padStart(2, '0');
                        }

                        updateTimer();
                        setInterval(updateTimer, 1000);
                    }
                }
            });

            function closeModal() {
                const container = document.getElementById("offerContainer");
                if (container) {
                    container.style.display = "none";
                    // نحفظ وقت الإغلاق في localStorage
                    localStorage.setItem("offerClosedTime", Date.now());
                }
            }
        </script>
    </div>
    {% endif %}

