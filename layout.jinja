<script>
(function () {
    const loader = document.getElementById("parent-loader");

    // fallback safety
    setTimeout(() => {
        loader && loader.classList.remove("active");
    }, 4000);

    window.addEventListener("load", () => {
        loader && loader.classList.remove("active");
    });
})();
</script>


