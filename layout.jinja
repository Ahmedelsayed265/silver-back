>

<!-- Loader -->
<div class="parent-loader active" id="parent-loader">
    <div class="loader-card">
        {% if settings.colors_header_loged %}
            {% set loaderLogoUrl = settings.colors_header_loged %}
        {% elif settings.header_logo %}
            {% set loaderLogoUrl = settings.header_logo %}
        {% else %}
            {% set loaderLogoUrl = store.logo %}
        {% endif %}
