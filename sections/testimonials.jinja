<section aria-label="{{ settings.title or 'قسم آراء العملاء' }}">
  <div class="container-fluid  section-padding-space">

    {% if settings.title or settings.subtitle %}
       <div class="d-flex flex-column mb-3">
            {% if settings.title %}
            <h1 class="section-title-custom w-fit" {% if settings.color1 %} style="color:{{settings.color1}}" {% endif %}>{{ settings.title }}</h1>
            {% endif %}
            {% if settings.subtitle %}
            <h2 class="sub-title" {% if settings.color2 %} style="color:{{settings.color2}}" {% endif %}>{{ settings.subtitle }}</h2>
            {% endif %}
       </div>
    {% endif %}

    <div class="testimonials-slider-wrapper">
      <div class="testimonials-sliders">
        {% for testimonial in safeget(settings, "testimonials", []) %}
          <article class="testimonials-customer" aria-label="تقييم من {{ testimonial.name }}">
            <div class="card-body">

             
