              {% if testimonial.text %}
                <div class="customer-text">
                  <p class="testimonial-text">{{ testimonial.text }}</p>
                </div>
              {% endif %}


              {% if testimonial.name %}
                <div class="account">
                  <span class="icon-account_circle_black_24dp testimonials-customer-icon" aria-hidden="true"></span>
                  <h3 class="testimonials-name">{{ testimonial.name }}</h3>
                </div>
              {% endif %}

       
              <div class="commit-svg" aria-hidden="true">
                <svg xmlns="http://www.w3.org/2000/svg" width="33" height="32" viewBox="0 0 33 32" fill="none">
                  <path d="M0.34 22.2C0.34 26.41 3.75 29.82 7.96 29.82C12.16 29.82 15.58 26.41 15.58 22.2C15.58 17.99 12.16 14.59 7.96 14.59C7.09 14.59 6.27 14.74 5.49 15C7.2 5.17 14.87 -1.17 7.76 4.05C-0.12 9.84 0.33 21.97 0.34 22.19C0.34 22.2 0.34 22.2 0.34 22.2Z" fill="#EEEEEE"/>
                  <path d="M17.1 22.2C17.1 26.41 20.51 29.82 24.72 29.82C28.92 29.82 32.33 26.41 32.33 22.2C32.33 17.99 28.92 14.59 24.72 14.59C23.85 14.59 23.02 14.74 22.25 15C23.96 5.17 31.63 -1.17 24.52 4.05C16.64 9.84 17.09 21.97 17.1 22.19C17.1 22.2 17.1 22.2 17.1 22.2Z" fill="#EEEEEE"/>
                </svg>
              </div>
            </div>
          </article>
        {% endfor %}
      </div>
    </div>
  </div>
</section>


 <script>
    document.addEventListener("DOMContentLoaded", function(){
        var arrowNextClass = (window.appDirection === 'ltr') ? 'fa-solid fa-angle-right': 'fa-solid fa-angle-left';
        var arrowPrevClass = (window.appDirection === 'ltr') ? 'fa-solid fa-angle-left' : 'fa-solid fa-angle-right';
        var screenWidth = window.screen.width;
        var autoPlayEnabled = {{ "true" if settings.auto else "false" }};
        var infiniteEnabled = {{ "true" if settings.infinite else "false" }};
        var hideDots = {{ "true" if settings.hide_dots else "false" }};
        var editingMode = {% if store.editing_mode %}true{% else %}false{% endif %};
        if(screenWidth >= 768 || editingMode){
            $('.testimonials-sliders').slick({
                slidesToShow: 3,
                slidesToScroll: 3,
                 infinite: infiniteEnabled,
                autoplay: autoPlayEnabled,
                arrows: false,
                dots: !hideDots,
                rtl: !(window.appDirection === 'ltr'),
                responsive: [
                    {
                        breakpoint: 1200,
                        settings: {
                            slidesToShow: 2,
                            slidesToScroll: 2
                        }
                    },
                    {
                        breakpoint: 768,
                        settings: {
                            slidesToShow: 1.5,
                            slidesToScroll: 1
                        }
                    },
                    {
                        breakpoint: 576,
                        settings: {
                            slidesToShow: 1.2,
                            slidesToScroll: 1
                        }
                    }
                ]
            });
        }
    });
</script>
